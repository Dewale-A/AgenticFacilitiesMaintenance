# =============================================================
# Environment Configuration
# Copy this file to .env and fill in your API keys
# =============================================================

# OpenAI API Key (required for embeddings and LLM calls)
OPENAI_API_KEY=your-openai-api-key-here

# Model Configuration
# The LLM model used by CrewAI agents for reasoning
OPENAI_MODEL_NAME=gpt-4o-mini

# Embedding model for RAG vector search
EMBEDDING_MODEL=text-embedding-ada-002

# =============================================================
# Governance Settings
# These thresholds control when human-in-the-loop is triggered
# =============================================================

# Work orders above this dollar amount require human approval
COST_THRESHOLD_FOR_APPROVAL=5000

# Confidence score below this triggers human review (0.0 to 1.0)
CONFIDENCE_THRESHOLD=0.7

# Enable/disable the full audit trail logging
AUDIT_TRAIL_ENABLED=true

# =============================================================
# Application Settings
# =============================================================

# FastAPI server configuration
API_HOST=0.0.0.0
API_PORT=8000

# Database path (SQLite)
DATABASE_PATH=src/data/facilities.db
